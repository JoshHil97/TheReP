{%- liquid
  assign featured_collection = section.settings.collection
  assign has_featured_products = false

  if featured_collection != blank and featured_collection.products_count > 0
    assign has_featured_products = true
  endif
-%}

{%- if has_featured_products or request.design_mode -%}
<section class="rp-featured-rentals">
  <div class="rp-shell">
    <div class="rp-section-head rp-section-head--split" data-rp-reveal>
      <div>
        {%- if section.settings.heading != blank -%}
          <h2 class="rp-section-heading">{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.copy != blank -%}
          <div class="rp-section-copy rte">{{ section.settings.copy }}</div>
        {%- endif -%}
      </div>

      {%- if section.settings.cta_label != blank and section.settings.cta_link != blank -%}
        <a class="rp-text-link" href="{{ section.settings.cta_link }}">{{ section.settings.cta_label }}</a>
      {%- endif -%}
    </div>

    <div class="rp-product-grid rp-product-grid--three">
      {%- if has_featured_products -%}
        {%- for product in featured_collection.products limit: section.settings.products_to_show -%}
          {% render 'rp-product-card', product: product %}
        {%- endfor -%}
      {%- elsif request.design_mode -%}
        <article class="rp-product-card is-placeholder">
          <div class="rp-product-card__content">
            <h3 class="rp-product-card__title">Select a collection to feature real rentals here.</h3>
          </div>
        </article>
      {%- endif -%}
    </div>
  </div>
</section>
{%- endif -%}

{% schema %}
{
  "name": "RP Featured rentals",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "See the silhouette first."
    },
    {
      "type": "richtext",
      "id": "copy",
      "label": "Copy",
      "default": "<p>Compare silhouette, colour and detail at a glance, then open each dress to choose your rental dates.</p>"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Products to show",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 3
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Link label",
      "default": "Rent now"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Link"
    }
  ],
  "presets": [
    {
      "name": "RP Featured rentals"
    }
  ]
}
{% endschema %}
