<section class="rp-announcement-bar" style="--rp-marquee-duration: {{ section.settings.rotation_speed | times: 6 }}s;">
  <div class="rp-shell rp-shell--wide">
    <div class="rp-announcement-bar__track" aria-label="Store announcements">
      <div class="rp-announcement-bar__marquee">
        {%- if section.blocks.size > 0 -%}
          {%- for repeat in (1..2) -%}
            {%- for block in section.blocks -%}
              <div class="rp-announcement-bar__item" {% if repeat == 1 %}{{ block.shopify_attributes }}{% endif %}>
                {%- if block.settings.link != blank -%}
                  <a href="{{ block.settings.link }}">{{ block.settings.text }}</a>
                {%- else -%}
                  <span>{{ block.settings.text }}</span>
                {%- endif -%}
              </div>
            {%- endfor -%}
          {%- endfor -%}
        {%- else -%}
          {%- for repeat in (1..8) -%}
            <div class="rp-announcement-bar__item">
              <span>Luxury dresses · Professionally cleaned · Prepaid returns &amp; Royal Mail delivery</span>
            </div>
          {%- endfor -%}
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "RP Announcement bar",
  "max_blocks": 5,
  "settings": [
    {
      "type": "range",
      "id": "rotation_speed",
      "label": "Marquee speed",
      "min": 3,
      "max": 8,
      "step": 1,
      "unit": "s",
      "default": 5
    }
  ],
  "blocks": [
    {
      "type": "message",
      "name": "Message",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Luxury dresses · Professionally cleaned · Prepaid returns & Royal Mail delivery"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Optional link"
        }
      ]
    }
  ]
}
{% endschema %}
