<section class="rp-password">
  <div class="rp-shell">
    <div class="rp-password__card" data-rp-reveal>
      {%- if section.settings.logo != blank -%}
        <div class="rp-password__logo">
          {{
            section.settings.logo
            | image_url: width: section.settings.logo_width
            | image_tag:
              class: 'rp-password__logo-image',
              alt: shop.name,
              widths: '160, 220, 320, 480'
          }}
        </div>
      {%- else -%}
        <h1 class="rp-password__brand">{{ shop.name }}</h1>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h2 class="rp-password__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}

      {%- if shop.password_message != blank -%}
        <div class="rp-password__copy rte">{{ shop.password_message }}</div>
      {%- elsif section.settings.copy != blank -%}
        <div class="rp-password__copy rte">{{ section.settings.copy }}</div>
      {%- endif -%}

      {% form 'storefront_password', class: 'rp-password__form' %}
        {%- if form.errors -%}
          <div class="rp-password__errors">
            {{ form.errors | default_errors }}
          </div>
        {%- endif -%}

        <label class="visually-hidden" for="Password">{{ 'general.password_page.login_form_password_label' | t }}</label>
        <div class="rp-password__input-row">
          <input
            id="Password"
            type="password"
            name="password"
            class="rp-password__input"
            autocomplete="current-password"
            placeholder="{{ section.settings.placeholder }}"
          >
          <button class="rp-button rp-button--solid" type="submit">{{ section.settings.button_label }}</button>
        </div>
      {% endform %}

      <div class="rp-password__meta">
        {%- if section.settings.secondary_link_label != blank and section.settings.secondary_link != blank -%}
          <a class="rp-text-link" href="{{ section.settings.secondary_link }}">{{ section.settings.secondary_link_label }}</a>
        {%- endif -%}
        <a class="rp-text-link" href="/admin">Store owner login</a>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Main password",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "range",
      "id": "logo_width",
      "label": "Logo width",
      "min": 120,
      "max": 280,
      "step": 10,
      "unit": "px",
      "default": 180
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Opening soon"
    },
    {
      "type": "richtext",
      "id": "copy",
      "label": "Copy",
      "default": "<p>A refined rental wardrobe is on its way. Enter the store password to preview the collection.</p>"
    },
    {
      "type": "text",
      "id": "placeholder",
      "label": "Password field placeholder",
      "default": "Enter store password"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Enter"
    },
    {
      "type": "text",
      "id": "secondary_link_label",
      "label": "Secondary link label",
      "default": "Back to home"
    },
    {
      "type": "url",
      "id": "secondary_link",
      "label": "Secondary link"
    }
  ]
}
{% endschema %}
