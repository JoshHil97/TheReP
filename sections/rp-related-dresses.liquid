{%- liquid
  assign related_collection = section.settings.collection

  if related_collection == blank
    for collection in product.collections
      if collection.products_count > 1
        assign related_collection = collection
        break
      endif
    endfor
  endif
-%}

<section class="rp-related-dresses">
  <div class="rp-shell">
    <div class="rp-section-head rp-section-head--split" data-rp-reveal>
      <h2 class="rp-section-heading">{{ section.settings.heading }}</h2>
      {%- if related_collection != blank -%}
        <a class="rp-text-link" href="{{ related_collection.url }}">View collection</a>
      {%- endif -%}
    </div>

    <div class="rp-product-grid rp-product-grid--three">
      {%- assign related_count = 0 -%}

      {%- if related_collection != blank -%}
        {%- for related_product in related_collection.products -%}
          {%- if related_product.id != product.id and related_count < section.settings.products_to_show -%}
            {% render 'rp-product-card', product: related_product %}
            {%- assign related_count = related_count | plus: 1 -%}
          {%- endif -%}
        {%- endfor -%}
      {%- endif -%}

      {%- if related_count == 0 and request.design_mode -%}
        <article class="rp-product-card is-placeholder">
          <div class="rp-product-card__media">
            {{ 'product-4' | placeholder_svg_tag: 'rp-product-card__placeholder' }}
          </div>
          <div class="rp-product-card__content">
            <h3 class="rp-product-card__title">Related dresses</h3>
            <p class="rp-product-card__note">Assign a collection or add this product to a collection to surface related styles here.</p>
          </div>
        </article>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "RP Related dresses",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Related dresses"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Optional collection override"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Products to show",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 3
    }
  ],
  "presets": [
    {
      "name": "RP Related dresses"
    }
  ]
}
{% endschema %}
