<section id="how-it-works" class="rp-how-it-works rp-tone--{{ section.settings.tone }}">
  <div class="rp-shell">
    <div class="rp-section-head" data-rp-reveal>
      {%- if section.settings.heading != blank -%}
        <h2 class="rp-section-heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
    </div>

    <div class="rp-how-it-works__grid">
      {%- for block in section.blocks -%}
        <article class="rp-how-it-works__card" data-rp-reveal {{ block.shopify_attributes }}>
          <span class="rp-how-it-works__index">0{{ forloop.index }}</span>
          <h3>{{ block.settings.title }}</h3>
          <p>{{ block.settings.copy }}</p>
        </article>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "RP How it works",
  "max_blocks": 3,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Luxury rental, made simple."
    },
    {
      "type": "select",
      "id": "tone",
      "label": "Tone",
      "options": [
        {
          "value": "light",
          "label": "Light"
        },
        {
          "value": "sand",
          "label": "Sand"
        }
      ],
      "default": "light"
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Choose your dress"
        },
        {
          "type": "textarea",
          "id": "copy",
          "label": "Copy",
          "default": "Select the piece that fits the moment, from intimate dinners to wedding weekends."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "RP How it works",
      "blocks": [
        {
          "type": "step"
        },
        {
          "type": "step"
        },
        {
          "type": "step"
        }
      ]
    }
  ]
}
{% endschema %}
