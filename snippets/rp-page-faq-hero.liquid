<div class="rp-page-main__support-hero">
  <div class="rp-page-main__support-copy" data-rp-reveal>
    <p class="rp-section-eyebrow">Frequently asked questions</p>
    <h1 class="rp-section-heading">Here&rsquo;s what you need to know...</h1>
    <div class="rp-section-copy rte">
      <p>Everything customers usually ask before, during, and after a rental, kept clear and easy to scan.</p>
    </div>
  </div>

  <div class="rp-page-main__support-media" data-rp-reveal>
    {% render 'rp-founder-photo',
      image: section.settings.image,
      class_name: 'rp-page-main__support-image rp-page-main__support-image--collage',
      alt: 'Founder photo collage'
    %}
  </div>
</div>
