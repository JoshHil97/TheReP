{%- liquid
  assign icon_name = icon | default: 'sparkle'
-%}

<div class="rp-trust-item">
  <span class="rp-trust-item__icon" aria-hidden="true">
    {%- case icon_name -%}
      {%- when 'return' -%}
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" focusable="false">
          <path d="M6.5 6.5H15V15" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"></path>
          <path d="M15 6.5 8.5 13" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"></path>
          <path d="M4.5 10.25a5.25 5.25 0 0 0 9 3.712" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"></path>
        </svg>
      {%- when 'calendar' -%}
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" focusable="false">
          <rect x="3.5" y="5" width="13" height="11.5" rx="2" stroke="currentColor" stroke-width="1.2"></rect>
          <path d="M6.5 3.5v3M13.5 3.5v3M3.5 8.5h13" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"></path>
        </svg>
      {%- when 'star' -%}
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" focusable="false">
          <path d="m10 3.75 1.85 3.75 4.15.6-3 2.925.7 4.125L10 13.2l-3.7 1.95.7-4.125-3-2.925 4.15-.6L10 3.75Z" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round"></path>
        </svg>
      {%- else -%}
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" focusable="false">
          <path d="M10 3.25c.532 2.682 1.386 3.536 4.068 4.068-2.682.532-3.536 1.386-4.068 4.068-.532-2.682-1.386-3.536-4.068-4.068 2.682-.532 3.536-1.386 4.068-4.068Z" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round"></path>
        </svg>
    {%- endcase -%}
  </span>

  <div class="rp-trust-item__content">
    {%- if title != blank -%}
      <p class="rp-trust-item__title">{{ title }}</p>
    {%- endif -%}
    {%- if copy != blank -%}
      <p class="rp-trust-item__copy">{{ copy }}</p>
    {%- endif -%}
  </div>
</div>
