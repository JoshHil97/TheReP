<!doctype html>
<html class="no-js" lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="theme-color" content="#e8eddc">
    <link rel="canonical" href="{{ canonical_url }}">

    {%- if settings.favicon != blank -%}
      <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 96, height: 96 }}">
    {%- endif -%}

    <title>
      {{ page_title }}
      {%- unless page_title contains shop.name %} | {{ shop.name }}{% endunless -%}
    </title>

    {%- if page_description -%}
      <meta name="description" content="{{ page_description | escape }}">
    {%- endif -%}

    {{ content_for_header }}

    {{ 'rp-base.css' | asset_url | stylesheet_tag }}
    {{ 'rp-sections.css' | asset_url | stylesheet_tag }}
    {{ 'rp-premium.css' | asset_url | stylesheet_tag }}
    <script src="{{ 'rp-interactions.js' | asset_url }}" defer="defer"></script>
  </head>

  <body class="rp-body template-password">
    <main id="MainContent" class="rp-main" role="main" tabindex="-1">
      {{ content_for_layout }}
    </main>
    <footer class="rp-password__footer">
      {{ powered_by_link }}
    </footer>
  </body>
</html>
